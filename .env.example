# ─────────────────────────────────────────────────────────────
#  Polymarket Quant Bot — Environment Config
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# Your Polygon wallet private key (from MetaMask or generated wallet)
# Must start with 0x
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Polymarket CLOB API Key (generated via the bot's --setup command)
CLOB_API_KEY=your_clob_api_key_here
CLOB_SECRET=your_clob_secret_here
CLOB_PASSPHRASE=your_clob_passphrase_here

# Polygon address (your public wallet address)
POLYGON_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# ─────────────────────────────────────────────────────────────
#  Risk Settings (edit these to control bot behavior)
# ─────────────────────────────────────────────────────────────

# Max USDC to risk per single market
MAX_POSITION_USDC=10.0

# Max total USDC deployed across all markets at once
MAX_TOTAL_EXPOSURE_USDC=50.0

# Stop the bot if daily losses hit this amount (USDC)
DAILY_LOSS_LIMIT_USDC=20.0

# Minimum spread % to consider a market (e.g. 0.05 = 5%)
MIN_SPREAD_THRESHOLD=0.05

# How many markets to scan and make markets on simultaneously
MAX_ACTIVE_MARKETS=3

# Order size in USDC per side
ORDER_SIZE_USDC=5.0

# How often to refresh/rebalance orders (seconds)
REFRESH_INTERVAL=30
